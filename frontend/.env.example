# Backend API: origin + port only, OR full URL ending in /api (see frontend/src/v2/api/api.js).
# `VITE_API_URL` is also supported for deployment platform compatibility.
# Production: https://your-api.onrender.com/api  (HTTPS; must match backend CORS FRONTEND_URL)
VITE_API_BASE_URL=http://localhost:5001
VITE_ENV=development

# Optional: Finnhub (US quote search in UI)
# VITE_FINNHUB_API_KEY=
