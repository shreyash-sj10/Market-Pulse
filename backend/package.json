{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "dev": "nodemon src/server.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/tests/**/*.test.js"
