{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest --runInBand --forceExit tests/unit src/middlewares/__tests__ src/services/__tests__",
    "test:integration": "jest --runInBand --forceExit tests/integration",
    "test:concurrency": "jest --runInBand --forceExit tests/concurrency",
    "test:security": "jest --runInBand --forceExit tests/security",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage --runInBand --forceExit tests/unit src/middlewares/__tests__ src/services/__tests__",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "verify:env": "node scripts/verify-env.js",
    "migrate:strict": "node scripts/strictMigration.js",
    "migrate:holdings": "node scripts/migrateHoldingsToCollection.js",
    "migrate:holding-trade-type": "node scripts/migrateHoldingTradeType.js",
    "seed:portfolio": "node scripts/seedPortfolioDemo.js"
  },
  "jest": {
    "globalSetup": "<rootDir>/tests/global/jest-mongo-global-setup.js",
    "globalTeardown": "<rootDir>/tests/global/jest-mongo-global-teardown.js",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup/jest-env-mongo.js"
    ],
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/coverage/"
    ],
    "collectCoverageFrom": [
      "src/engines/entry.engine.js",
      "src/engines/exit.engine.js",
      "src/engines/reflection.engine.js",
      "src/services/risk.engine.js",
      "src/services/behavior.engine.js",
      "src/services/mistakeAnalysis.service.js",
      "src/middlewares/auth.middleware.js",
      "src/middlewares/validateTradePayload.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 85,
        "lines": 85,
        "statements": 85
      },
      "src/engines/entry.engine.js": {
        "branches": 75,
        "functions": 90,
        "lines": 90,
        "statements": 90
      },
      "src/engines/exit.engine.js": {
        "branches": 75,
        "functions": 90,
        "lines": 90,
        "statements": 90
      },
      "src/engines/reflection.engine.js": {
        "branches": 70,
        "functions": 90,
        "lines": 85,
        "statements": 85
      },
      "src/services/risk.engine.js": {
        "branches": 75,
        "functions": 85,
        "lines": 85,
        "statements": 85
      },
      "src/services/behavior.engine.js": {
        "branches": 75,
        "functions": 85,
        "lines": 85,
        "statements": 85
      },
      "src/services/mistakeAnalysis.service.js": {
        "branches": 80,
        "functions": 85,
        "lines": 85,
        "statements": 85
      },
      "src/middlewares/auth.middleware.js": {
        "branches": 75,
        "functions": 80,
        "lines": 80,
        "statements": 80
      },
      "src/middlewares/validateTradePayload.js": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.5",
    "cors": "^2.8.6",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.2",
    "morgan": "^1.10.1",
    "p-limit": "^3.1.0",
    "p-queue": "^6.6.2",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.11.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yahoo-finance2": "^3.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "kill-port": "^2.0.1",
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2"
  }
}
