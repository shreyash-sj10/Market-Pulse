# --- Required ---
PORT=5001
# Local: mongodb://127.0.0.1:27017/trade_engine
# Atlas: mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/dbname?retryWrites=true&w=majority
# Transactions (runInTransaction): use a replica set (Atlas M0+ or local rs.initiate()).
#
# Jest: by default `npm test` starts an in-memory replica set and sets MONGO_URI (see tests/setup/jest-env-mongo.js).
# To run integration tests against this file's MONGO_URI instead (e.g. Atlas), set:
# USE_EXTERNAL_MONGO=true

JWT_SECRET=replace_with_long_random_string_min_32_chars
FRONTEND_URL=http://localhost:5180

# --- Environment ---
NODE_ENV=development
# production: NODE_ENV=production (hides stack traces in API errors)

# --- Deployment / scale (P1-C) ---
# Outbox worker, stop-loss monitor, and execution executor use in-process setInterval loops.
# Run exactly ONE web/API instance (e.g. Railway replicas = 1) until you add Redis locks,
# a dedicated worker dyno, or BullMQ-only scheduling. See docs/BACKGROUND_WORKERS_SCALE.md.

# --- Security / dev tooling (M-01) ---
# Set to "true" ONLY for automated local tests that cannot send CSRF headers.
# Default / unset = CSRF enforced on /auth/refresh in all NODE_ENV values.
# SKIP_CSRF_DEV=false

# --- Optional auth TTLs ---
JWT_EXPIRES_IN=7d
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# --- Optional: Redis (queues / AI cache); omit or USE_REDIS=false for degraded sync ---
# REDIS_URL=redis://127.0.0.1:6379
# USE_REDIS=false

# --- Market Calendar (trading-calendar Docker service) ---
# Docker: ghcr.io/apptastic-software/trading-calendar:latest
# Run:    docker run -p 8080:8080 ghcr.io/apptastic-software/trading-calendar:latest
# URL of the running container (no trailing slash).
# TRADING_CALENDAR_URL=http://localhost:8080
#
# ISO 10383 MIC code for the exchange.
#   XNSE = NSE (National Stock Exchange of India) — default, matches .NS symbols
#   XBOM = BSE (Bombay Stock Exchange)
# CALENDAR_EXCHANGE_MIC=XNSE
#
# How often the in-memory cache is refreshed from MongoDB (ms). Default: 60 000 (60 s).
# CALENDAR_CACHE_REFRESH_MS=60000
#
# How often the Docker service is re-queried for updated holidays (ms). Default: 86 400 000 (24 h).
# CALENDAR_SYNC_INTERVAL_MS=86400000

# --- Optional: intelligence (never commit real keys) ---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

# Finnhub (news + live quote fallback). Node.js env var — NOT the Vite VITE_ prefix.
# FINNHUB_API_KEY=

# Max relative drift |clientPrice - livePrice| / livePrice before 422 PRICE_STALE (default 0.005 = 0.5%).
# MAX_CLIENT_PRICE_DRIFT_PCT=0.005

# Quote cache: Redis hot tier uses MARKET_CACHE_TTL_MS; stale tier for graceful reads after upstream failure.
# MARKET_STALE_TTL_SEC=1800

# Auth middleware user cache (Redis) TTL seconds when USE_REDIS=true
# AUTH_CACHE_TTL_SEC=30

# Square-off liquidation concurrency (intraday positions)
# SQUAREOFF_CONCURRENCY=10
# IST clock time when squareoff is allowed to run (weekdays only; Mongo claim per day).
# SQUAREOFF_TIME_IST=15:20
# Reclaim stale RUNNING squareoff claims after this many ms (process crash mid-run).
# SQUAREOFF_CLAIM_STALE_MS=1800000
# Log SQUAREOFF_STUCK when another instance holds RUNNING longer than this (before stale reclaim).
# SQUAREOFF_STUCK_WARN_MS=180000

# --- Optional: logging ---
# LOG_LEVEL=info

# --- Optional: Mongo pool / connect (production tuning) ---
# MONGO_MAX_POOL_SIZE=10
# MONGO_CONNECT_RETRIES=3
# MONGO_SERVER_SELECTION_MS=10000

# --- Optional: analytics / reflection (defaults in code if unset) ---
# ANALYTICS_SNAPSHOT_VALID_MS=86400000
# RECENT_TRADE_SNAPSHOT_BYPASS_MS=120000
# REFLECTION_MAX_ATTEMPTS=5
# EXECUTION_LOCK_TTL_SECONDS=604800
# OUTBOX_MAX_ATTEMPTS=8
# OUTBOX_POLL_MS=5000
# USER_ANALYTICS_SNAPSHOT outbox: failures retried until this count, then row FAILED (default 3).
# ANALYTICS_SNAPSHOT_MAX_RETRY=3

# --- Optional: trade HTTP rate limit (per IP; default max 5 per 10s outside test) ---
# Raise temporarily for k6 / load tools (see README). Do not leave high in production.
# TRADE_RATE_LIMIT_WINDOW_MS=10000
# TRADE_RATE_LIMIT_MAX=200
